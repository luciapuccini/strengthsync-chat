
OPENAI_API_KEY=
BRAINTRUST_API_KEY=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Temporal Cloud (optional) — when set, `pnpm temporal:worker` / `pnpm temporal:api`
# connect to Cloud instead of the local dev server. Leave empty for local dev.
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_API_KEY=

# CORS for the Temporal Hono API (`pnpm temporal:api`). Must match the origin you
# open in the browser (scheme + host + port). For Tailscale gym access, use the
# Mac MagicDNS name or Tailscale IP, e.g. http://strengthsync.tailXXXX.ts.net:5173
# UI_ORIGIN=http://localhost:5173

# Client-side Temporal API base URL is NOT read from this file. Put it in
# `.env.local` (Vite) instead, e.g.:
#   VITE_TEMPORAL_API_URL=http://strengthsync.tailXXXX.ts.net:3001
# Restart `pnpm dev` after changing any VITE_* value.
