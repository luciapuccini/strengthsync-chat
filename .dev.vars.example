
OPENAI_API_KEY=
BRAINTRUST_API_KEY=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Temporal Cloud (optional) — when set, `pnpm temporal:worker` / `pnpm temporal:api`
# connect to Cloud instead of the local dev server. Leave empty for local dev.
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_API_KEY=

# CORS for the Temporal Hono API (`pnpm temporal:api`). Must match the browser
# Origin exactly (scheme + host + port). Comma-separated for dual access:
#   UI_ORIGIN=http://localhost:5173,http://mac:5173
# Bare hosts without http:// will be normalized, but prefer the full origin.
UI_ORIGIN=http://localhost:5173

# Client-side Temporal API base URL is NOT read from this file. Put it in
# `.env.local` (Vite) instead — and match the host you open in the browser:
#   VITE_TEMPORAL_API_URL=http://localhost:3001
#   VITE_TEMPORAL_API_URL=http://mac:3001
# Restart `pnpm dev` after changing any VITE_* value.
