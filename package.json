{
  "name": "strengthsync-chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:local": "trap 'kill 0' EXIT; pnpm run temporal:api & pnpm run temporal:worker & pnpm run dev",
    "eval": "dotenv -e .dev.vars -- braintrust eval evals/chat.eval.ts",
    "temporal:dev": "temporal server start-dev",
    "temporal:worker": "dotenv -e .dev.vars -- tsx watch src/temporal/worker.ts",
    "temporal:api": "dotenv -e .dev.vars -- tsx watch src/temporal/server.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@base-ui/react": "^1.6.0",
    "@cloudflare/ai-chat": "^0.9.3",
    "@cloudflare/workers-types": "^4.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/node-server": "^2.0.10",
    "@tanstack/react-table": "^8.21.3",
    "@temporalio/activity": "^1.20.3",
    "@temporalio/client": "^1.20.3",
    "@temporalio/worker": "^1.20.3",
    "@temporalio/workflow": "^1.20.3",
    "agents": "^0.17.3",
    "ai": "^7.0.22",
    "autoevals": "^0.3.0",
    "braintrust": "^3.21.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
